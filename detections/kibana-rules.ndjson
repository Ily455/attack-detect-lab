{"id":"a1b2c3d4-0001-4000-8000-000000000001","name":"T1059.004 - Unix Shell Execution","description":"Detects Unix shell execution via execve syscall — MITRE ATT&CK T1059.004. Covers sh, bash, and dash invoked with -c flag.","risk_score":47,"severity":"medium","type":"query","query":"message: \"type=EXECVE\" AND (message: \"a0=\\\"sh\\\"\" OR message: \"a0=\\\"bash\\\"\" OR message: \"a0=\\\"dash\\\"\")","language":"kuery","index":["attack-detect-logs-*"],"enabled":true,"interval":"5m","from":"now-6m","author":["Ilyass El Annid"],"tags":["attack.execution","attack.t1059.004","linux","auditd"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0002","name":"Execution","reference":"https://attack.mitre.org/tactics/TA0002/"},"technique":[{"id":"T1059","name":"Command and Scripting Interpreter","reference":"https://attack.mitre.org/techniques/T1059/","subtechnique":[{"id":"T1059.004","name":"Unix Shell","reference":"https://attack.mitre.org/techniques/T1059/004/"}]}]}],"false_positives":["Legitimate shell scripts run by administrators","System services invoking shell commands"],"max_signals":100,"version":1,"rule_id":"attack-detect-t1059-004"}
{"id":"a1b2c3d4-0002-4000-8000-000000000002","name":"T1053.003 - Cron Job Persistence","description":"Detects crontab invocation — MITRE ATT&CK T1053.003. crontab called from a non-system process, especially with a file argument from /tmp, is a strong persistence indicator.","risk_score":47,"severity":"medium","type":"query","query":"message: \"type=EXECVE\" AND message: \"a0=\\\"crontab\\\"\"","language":"kuery","index":["attack-detect-logs-*"],"enabled":true,"interval":"5m","from":"now-6m","author":["Ilyass El Annid"],"tags":["attack.persistence","attack.t1053.003","linux","auditd"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0003","name":"Persistence","reference":"https://attack.mitre.org/tactics/TA0003/"},"technique":[{"id":"T1053","name":"Scheduled Task/Job","reference":"https://attack.mitre.org/techniques/T1053/","subtechnique":[{"id":"T1053.003","name":"Cron","reference":"https://attack.mitre.org/techniques/T1053/003/"}]}]}],"false_positives":["Legitimate cron job management by administrators","Package manager installing cron jobs"],"max_signals":100,"version":1,"rule_id":"attack-detect-t1053-003"}
{"id":"a1b2c3d4-0003-4000-8000-000000000003","name":"T1136.001 - Local Account Creation","description":"Detects local account creation via useradd or adduser — MITRE ATT&CK T1136.001.","risk_score":47,"severity":"medium","type":"query","query":"message: \"type=EXECVE\" AND (message: \"a0=\\\"useradd\\\"\" OR message: \"a0=\\\"adduser\\\"\")","language":"kuery","index":["attack-detect-logs-*"],"enabled":true,"interval":"5m","from":"now-6m","author":["Ilyass El Annid"],"tags":["attack.persistence","attack.t1136.001","linux","auditd"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0003","name":"Persistence","reference":"https://attack.mitre.org/tactics/TA0003/"},"technique":[{"id":"T1136","name":"Create Account","reference":"https://attack.mitre.org/techniques/T1136/","subtechnique":[{"id":"T1136.001","name":"Local Account","reference":"https://attack.mitre.org/techniques/T1136/001/"}]}]}],"false_positives":["Legitimate user provisioning by administrators","System package installation creating service accounts"],"max_signals":100,"version":1,"rule_id":"attack-detect-t1136-001"}
{"id":"a1b2c3d4-0004-4000-8000-000000000004","name":"T1087.001 - Local Account Discovery","description":"Detects local account enumeration via cat /etc/passwd, /etc/shadow, or lsof — MITRE ATT&CK T1087.001.","risk_score":21,"severity":"low","type":"query","query":"message: \"type=EXECVE\" AND (message: \"a1=\\\"/etc/passwd\\\"\" OR message: \"a1=\\\"/etc/shadow\\\"\" OR message: \"a0=\\\"lsof\\\"\")","language":"kuery","index":["attack-detect-logs-*"],"enabled":true,"interval":"5m","from":"now-6m","author":["Ilyass El Annid"],"tags":["attack.discovery","attack.t1087.001","linux","auditd"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0007","name":"Discovery","reference":"https://attack.mitre.org/tactics/TA0007/"},"technique":[{"id":"T1087","name":"Account Discovery","reference":"https://attack.mitre.org/techniques/T1087/","subtechnique":[{"id":"T1087.001","name":"Local Account","reference":"https://attack.mitre.org/techniques/T1087/001/"}]}]}],"false_positives":["System monitoring tools","Legitimate administrator activity"],"max_signals":100,"version":1,"rule_id":"attack-detect-t1087-001"}
{"id":"a1b2c3d4-0005-4000-8000-000000000005","name":"T1083 - File and Directory Discovery","description":"Detects filesystem enumeration via find, tree, or showmount — MITRE ATT&CK T1083.","risk_score":21,"severity":"low","type":"query","query":"message: \"type=EXECVE\" AND (message: \"a0=\\\"find\\\"\" OR message: \"a0=\\\"showmount\\\"\" OR message: \"a0=\\\"tree\\\"\")","language":"kuery","index":["attack-detect-logs-*"],"enabled":true,"interval":"5m","from":"now-6m","author":["Ilyass El Annid"],"tags":["attack.discovery","attack.t1083","linux","auditd"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0007","name":"Discovery","reference":"https://attack.mitre.org/tactics/TA0007/"},"technique":[{"id":"T1083","name":"File and Directory Discovery","reference":"https://attack.mitre.org/techniques/T1083/"}]}],"false_positives":["Package managers and system tools using find","Backup scripts","Legitimate administrator enumeration"],"max_signals":100,"version":1,"rule_id":"attack-detect-t1083"}
{"id":"a1b2c3d4-0006-4000-8000-000000000006","name":"T1105 - Ingress Tool Transfer","description":"Detects file transfer via curl, wget, rsync, or scp — MITRE ATT&CK T1105. Covers download-and-execute patterns and lateral file movement.","risk_score":47,"severity":"medium","type":"query","query":"message: \"type=EXECVE\" AND (message: \"a0=\\\"curl\\\"\" OR message: \"a0=\\\"wget\\\"\" OR message: \"a0=\\\"rsync\\\"\" OR message: \"a0=\\\"scp\\\"\")","language":"kuery","index":["attack-detect-logs-*"],"enabled":true,"interval":"5m","from":"now-6m","author":["Ilyass El Annid"],"tags":["attack.command-and-control","attack.t1105","linux","auditd"],"threat":[{"framework":"MITRE ATT&CK","tactic":{"id":"TA0011","name":"Command and Control","reference":"https://attack.mitre.org/tactics/TA0011/"},"technique":[{"id":"T1105","name":"Ingress Tool Transfer","reference":"https://attack.mitre.org/techniques/T1105/"}]}],"false_positives":["Package managers","Legitimate software update scripts","System health checks"],"max_signals":100,"version":1,"rule_id":"attack-detect-t1105"}
